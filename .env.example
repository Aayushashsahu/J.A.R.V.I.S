# Database Configuration
POSTGRES_USER=founderos
POSTGRES_PASSWORD=founderos_password
POSTGRES_DB=founderos_db

# Security
# Run `openssl rand -hex 32` to generate a secret
JWT_SECRET_KEY=your_super_secret_jwt_key_here

# LLM Providers
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# GBrain bootstrap (no default — must be set, generate with `openssl rand -hex 32`)
GBRAIN_ADMIN_BOOTSTRAP_TOKEN=replace_with_generated_token

# Next.js Variables
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
JARVIS_VAULT_PATH=C:\J.A.R.V.I.S\vault
